<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="5dp">

    <!-- MAIN SCREEN -->
    <ScrollView
        android:id="@+id/mainScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/mainLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOOLBAR -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/txtBg"
                android:title="Inventory Dashboard"
                android:titleTextColor="@color/white"/>

            <!-- TOTAL CARDS -->
            <LinearLayout
                android:id="@+id/llTopCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp">

                <!-- TOTAL SALES -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTotalSales"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="6dp"
                    android:backgroundTint="@color/add">

                    <TextView
                        android:id="@+id/tvTotalSales"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Total Sales"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>
                </androidx.cardview.widget.CardView>

                <!-- TOTAL EXPENSES -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTotalExpenses"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="6dp"
                    android:backgroundTint="@color/remove">

                    <TextView
                        android:id="@+id/tvTotalExpenses"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Total Expenses"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- PROFIT -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfit"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                android:backgroundTint="@color/profit">

                <TextView
                    android:id="@+id/tvProfit"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Profit"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/white"/>
            </androidx.cardview.widget.CardView>

            <!-- ADD TRANSACTION -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAddTransaction"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:backgroundTint="@color/add">

                <TextView
                    android:id="@+id/tvAddTransaction"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Add Transaction"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
            </androidx.cardview.widget.CardView>

            <!-- VIEW TRANSACTION -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewTransaction"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:backgroundTint="@color/view">

                <TextView
                    android:id="@+id/tvViewTransaction"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="View Transaction"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
            </androidx.cardview.widget.CardView>

            <!-- VIEW REPORTS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewReports"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:backgroundTint="@color/profit">

                <TextView
                    android:id="@+id/tvViewReports"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="View Reports"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- SIDE NAVBAR -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu"/>

</androidx.drawerlayout.widget.DrawerLayout>